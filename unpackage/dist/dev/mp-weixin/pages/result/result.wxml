<view class="container data-v-8b0659b4"><block wx:if="{{mode==='result'}}"><view class="result-mode data-v-8b0659b4"><view class="result-header data-v-8b0659b4"><text class="mode-kicker data-v-8b0659b4">{{result.modeKicker}}</text><view class="type-badge data-v-8b0659b4">{{result.badge}}</view></view><view class="type-info data-v-8b0659b4"><text class="type-code data-v-8b0659b4">{{result.type.code}}</text><text class="type-name data-v-8b0659b4">{{result.type.cn}}</text></view><view class="poster-box data-v-8b0659b4" id="posterBox"><block wx:if="{{personalityImages[result.type.code]}}"><image class="poster-image data-v-8b0659b4" src="{{personalityImages[result.type.code]}}" mode="widthFix"></image></block><block wx:else><view class="no-poster data-v-8b0659b4"><text class="no-poster-text data-v-8b0659b4">{{result.type.code}}</text></view></block></view><view class="intro-section data-v-8b0659b4"><text class="intro-text data-v-8b0659b4">{{result.type.intro}}</text></view><view class="desc-section data-v-8b0659b4"><text class="desc-text data-v-8b0659b4">{{result.type.desc}}</text></view><view class="disclaimer data-v-8b0659b4"><text class="disclaimer-text data-v-8b0659b4"> 本测试仅供娱乐。隐藏人格和傻乐兜底都属于作者故意埋的损招，请勿把它当成医学、心理学、相学、命理学或灵异学依据。 </text></view><view class="actions data-v-8b0659b4"><button data-event-opts="{{[['tap',[['savePoster',['$event']]]]]}}" class="action-btn primary data-v-8b0659b4" bindtap="__e">保存人格卡</button><button data-event-opts="{{[['tap',[['restartTest',['$event']]]]]}}" class="action-btn secondary data-v-8b0659b4" bindtap="__e">重新测试</button><button data-event-opts="{{[['tap',[['goToDownload',['$event']]]]]}}" class="action-btn secondary data-v-8b0659b4" bindtap="__e">查看所有人格卡</button></view></view></block><block wx:else><view class="download-mode data-v-8b0659b4"><view class="download-header data-v-8b0659b4"><text class="download-title data-v-8b0659b4">所有人格卡</text><text class="download-subtitle data-v-8b0659b4">{{"共 "+$root.g0+" 种人格类型"}}</text></view><view class="personality-list data-v-8b0659b4"><block wx:for="{{personalityList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="code"><view data-event-opts="{{[['tap',[['previewPersonality',['$0'],[[['personalityList','code',item.code]]]]]]]}}" class="personality-card data-v-8b0659b4" bindtap="__e"><view class="card-preview data-v-8b0659b4"><block wx:if="{{personalityImages[item.code]}}"><image class="card-thumb data-v-8b0659b4" src="{{personalityImages[item.code]}}" mode="aspectFill"></image></block><block wx:else><view class="card-placeholder data-v-8b0659b4"><text class="placeholder-text data-v-8b0659b4">{{item.code}}</text></view></block></view><view class="card-info data-v-8b0659b4"><text class="card-code data-v-8b0659b4">{{item.code}}</text><text class="card-name data-v-8b0659b4">{{item.cn}}</text></view></view></block></view><view class="download-actions data-v-8b0659b4"><button data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn data-v-8b0659b4" bindtap="__e">返回首页</button></view></view></block><block wx:if="{{showPreview}}"><view data-event-opts="{{[['tap',[['closePreview',['$event']]]]]}}" class="preview-modal data-v-8b0659b4" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="preview-content data-v-8b0659b4" catchtap="__e"><block wx:if="{{previewItem&&personalityImages[previewItem.code]}}"><image class="preview-image data-v-8b0659b4" src="{{personalityImages[previewItem.code]}}" mode="widthFix"></image></block><block wx:if="{{previewItem}}"><view class="preview-info data-v-8b0659b4"><text class="preview-code data-v-8b0659b4">{{previewItem.code}}</text><text class="preview-name data-v-8b0659b4">{{previewItem.cn}}</text><text class="preview-intro data-v-8b0659b4">{{previewItem.intro}}</text></view></block><button data-event-opts="{{[['tap',[['saveSinglePoster',['$event']]]]]}}" class="save-single-btn data-v-8b0659b4" bindtap="__e">保存此卡片</button></view></view></block></view>
<view class="container data-v-3e202046"><view class="progress-bar data-v-3e202046"><view class="progress-fill data-v-3e202046" style="{{'width:'+(progressPercent+'%')+';'}}"></view></view><block wx:if="{{currentQuestion}}"><scroll-view class="question-scroll data-v-3e202046" scroll-y="{{true}}"><view class="question-card data-v-3e202046"><text class="question-text data-v-3e202046" user-select="{{true}}">{{currentQuestion.text}}</text></view><view class="options data-v-3e202046"><block wx:for="{{currentQuestion.options}}" wx:for-item="option" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['selectOption',['$0'],[[['currentQuestion.options','',index,'value']]]]]]]}}" class="{{['option-item','data-v-3e202046',(selectedValue===option.value)?'selected':'']}}" bindtap="__e"><view class="option-letter data-v-3e202046">{{['A','B','C','D'][index]}}</view><text class="option-text data-v-3e202046" user-select="{{true}}">{{option.label}}</text></view></block></view></scroll-view></block><view class="footer data-v-3e202046"><button class="nav-btn prev data-v-3e202046" disabled="{{currentIndex===0}}" data-event-opts="{{[['tap',[['prevQuestion',['$event']]]]]}}" bindtap="__e"> 上一题 </button><block wx:if="{{isShowNextBtn}}"><button class="nav-btn next data-v-3e202046" disabled="{{!selectedValue}}" data-event-opts="{{[['tap',[['nextQuestion',['$event']]]]]}}" bindtap="__e"> 下一题 </button></block><block wx:if="{{isShowSubmitBtn}}"><button class="nav-btn submit data-v-3e202046" disabled="{{!canSubmit}}" data-event-opts="{{[['tap',[['submitTest',['$event']]]]]}}" bindtap="__e"> 提交测试 </button></block></view></view>